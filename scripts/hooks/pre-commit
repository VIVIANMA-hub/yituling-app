#!/bin/sh
# 一图灵 pre-commit 钩子（POSIX sh，兼容 macOS 自带 /bin/sh）
# 双保险：即使 .gitignore 漏了，仍然在提交瞬间拦截密钥 / 患者隐私 / 商业机密。
#
# 拦截分三类：
#   A. 文件名直接拒绝：任何 cloudfunctions/*/config.json、.env、.keystore、.p12、.mobileprovision
#   B. 文件内容密钥模式：百度 AK/SK、阿里云/腾讯云 AKID、OpenAI sk-、Bearer、JWT 等
#   C. 患者隐私 / 商业机密：身份证号、医院名、股权/估值/注册资本等
#
# 命中即 exit 1。绕过：git commit --no-verify（CLAUDE.md 明确未授权禁止）。
# 例外白名单：行内含 EXAMPLE / placeholder / your_key_here / xxxxx / REPLACE_ 视为示例，跳过密钥模式拦截。

set -u

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

staged=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$staged" ] && exit 0

# 用文件累计违规数（管道子 shell 里赋值不会回传到父 shell）
VIOL_FILE=".git/_precommit_violations"
: > "$VIOL_FILE"

bump_violation() {
  echo "$1" >> "$VIOL_FILE"
}

# ============== A. 文件名黑名单 ==============
printf '%s\n' "$staged" | while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    *cloudfunctions/*/config.json)
      printf "${RED}✗ 禁止提交云函数 config.json：%s${NC}\n" "$f" >&2
      printf "  ${YELLOW}密钥应只在本地存在，云端走 secrets_cache${NC}\n" >&2
      bump_violation "FILENAME"
      ;;
    *project.private.config.json)
      printf "${RED}✗ 禁止提交微信私有配置：%s${NC}\n" "$f" >&2
      bump_violation "FILENAME"
      ;;
    *.env|*.env.*)
      printf "${RED}✗ 禁止提交 .env：%s${NC}\n" "$f" >&2
      bump_violation "FILENAME"
      ;;
    *.keystore|*.jks|*.p12|*.mobileprovision|*.cer|*.certSigningRequest)
      printf "${RED}✗ 禁止提交证书 / 密钥库：%s${NC}\n" "$f" >&2
      bump_violation "FILENAME"
      ;;
  esac
done

# ============== B/C. 内容扫描 ==============
patterns_keys='
BAIDU_AK_FALLBACK|(api_key|client_id)["'\'' :=]+[A-Za-z0-9]{20,30}
BAIDU_SK_FALLBACK|(secret_key|client_secret)["'\'' :=]+[A-Za-z0-9]{32,40}
TENCENT_AKID|AKID[A-Za-z0-9]{32,40}
ALIYUN_AKID|LTAI[A-Za-z0-9]{16,28}
OPENAI_SK|sk-[A-Za-z0-9]{20,}
ANTHROPIC_SK|sk-ant-[A-Za-z0-9-]{20,}
GENERIC_BEARER|Bearer +[A-Za-z0-9._-]{20,}
JWT|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}
PRIVATE_KEY|BEGIN [A-Z ]*PRIVATE KEY
WX_APPID_HARDCODED|wx[a-f0-9]{16}
'

patterns_pii='
CHINA_ID_18|[^0-9]([1-9][0-9]{5}(19|20)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])[0-9]{3}[0-9Xx])[^0-9]
HOSPITAL_TAIL|[一-龥]{2,8}(人民医院|妇幼保健院|附属医院|中医院|肿瘤医院)
'

patterns_biz='
EQUITY|股权|估值|注册资本|股东协议|Vesting|MOIC|IRR|AB 股|AB股|对赌
'

TEXT_EXT_RE='\.(js|ts|vue|json|md|txt|yaml|yml|sh|html|css|scss|conf|env|key|pem|cfg|ini|xml|properties|toml)$'

# 示例 / 占位 / 测试样本白名单：含这些标记的行不参与密钥扫描
EXAMPLE_WHITELIST='EXAMPLE|your_key_here|YOUR_KEY|placeholder|REPLACE_|xxxxx|x{8,}|<your-|<replace-|mock|MOCK|fake|FAKE'

scan_added_lines() {
  f="$1"
  added=$(git diff --cached -U0 -- "$f" | sed -n 's/^+\([^+].*\)/\1/p')
  [ -z "$added" ] && return 0

  added_filtered=$(printf '%s\n' "$added" | grep -Ev "$EXAMPLE_WHITELIST" 2>/dev/null || true)

  printf '%s\n' "$patterns_keys" | while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    name=$(printf '%s' "$entry" | cut -d'|' -f1)
    re=$(printf '%s' "$entry" | cut -d'|' -f2-)
    if [ -n "$added_filtered" ] && printf '%s' "$added_filtered" | grep -E -q -e "$re"; then
      printf "${RED}✗ %s 命中密钥模式 [%s]${NC}\n" "$f" "$name" >&2
      printf "  ${YELLOW}staged 行包含疑似密钥；如确为示例请加 EXAMPLE/placeholder 标记${NC}\n" >&2
      bump_violation "KEY_$name"
    fi
  done

  printf '%s\n' "$patterns_pii" | while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    name=$(printf '%s' "$entry" | cut -d'|' -f1)
    re=$(printf '%s' "$entry" | cut -d'|' -f2-)
    if printf '%s' "$added" | grep -E -q -e "$re"; then
      printf "${RED}✗ %s 命中 PIPL 模式 [%s]${NC}\n" "$f" "$name" >&2
      printf "  ${YELLOW}请先脱敏（身份证号 / 真实医院名 / 患者编号）${NC}\n" >&2
      bump_violation "PII_$name"
    fi
  done

  case "$f" in
    *docs/dev-diary/*) ;;
    *)
      printf '%s\n' "$patterns_biz" | while IFS= read -r entry; do
        [ -z "$entry" ] && continue
        name=$(printf '%s' "$entry" | cut -d'|' -f1)
        re=$(printf '%s' "$entry" | cut -d'|' -f2-)
        if printf '%s' "$added" | grep -E -q -e "$re"; then
          printf "${RED}✗ %s 命中商业机密词 [%s]${NC}\n" "$f" "$name" >&2
          printf "  ${YELLOW}股权 / 估值 / 注册资本类信息应放仓库外的 BP 文件夹${NC}\n" >&2
          bump_violation "BIZ_$name"
        fi
      done
      ;;
  esac
}

printf '%s\n' "$staged" | while IFS= read -r f; do
  [ -z "$f" ] && continue
  [ -f "$f" ] || continue
  case "$f" in
    *scripts/hooks/pre-commit) continue ;;
    *.gitignore) continue ;;
  esac
  if ! printf '%s' "$f" | grep -E -q "$TEXT_EXT_RE"; then
    continue
  fi
  scan_added_lines "$f"
done

viol_count=$(wc -l < "$VIOL_FILE" 2>/dev/null | tr -d ' ')
viol_count=${viol_count:-0}
rm -f "$VIOL_FILE"

if [ "$viol_count" != "0" ]; then
  printf "\n${RED}===== pre-commit 拦截 %s 处。请处理后再 commit。=====${NC}\n" "$viol_count" >&2
  printf "${YELLOW}如真要绕过（极少数情况），运行：git commit --no-verify${NC}\n" >&2
  printf "${YELLOW}CLAUDE.md 明确未授权时不要 --no-verify。${NC}\n" >&2
  exit 1
fi

exit 0
